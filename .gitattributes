# Auto-detect text files and normalize line endings
* text=auto

# Force CRLF on Windows for these file types
*.{css,html,js,jsx,ts,tsx,json,md,yml,yaml} text eol=lf

# Keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
